<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans
       http://www.springframework.org/schema/beans/spring-beans.xsd">

    <bean id="java" class="com.cognizant.springlearn.Skill">
        <property name="id" value="1"/>
        <property name="name" value="Java"/>
    </bean>

    <bean id="python" class="com.cognizant.springlearn.Skill">
        <property name="id" value="2"/>
        <property name="name" value="Python"/>
    </bean>

    <bean id="hr" class="com.cognizant.springlearn.Department">
        <property name="id" value="1"/>
        <property name="name" value="HR"/>
    </bean>

    <bean id="it" class="com.cognizant.springlearn.Department">
        <property name="id" value="2"/>
        <property name="name" value="IT"/>
    </bean>

    <bean id="emp1" class="com.cognizant.springlearn.Employee">
        <property name="id" value="E001"/>
        <property name="name" value="Alice"/>
        <property name="salary" value="50000.0"/>
        <property name="department" ref="hr"/>
        <property name="skills">
            <list>
                <ref bean="java"/>
            </list>
        </property>
    </bean>

    <bean id="emp2" class="com.cognizant.springlearn.Employee">
        <property name="id" value="E002"/>
        <property name="name" value="Bob"/>
        <property name="salary" value="60000.0"/>
        <property name="department" ref="it"/>
        <property name="skills">
            <list>
                <ref bean="java"/>
                <ref bean="python"/>
            </list>
        </property>
    </bean>

    <bean id="emp3" class="com.cognizant.springlearn.Employee">
        <property name="id" value="E003"/>
        <property name="name" value="Charlie"/>
        <property name="salary" value="55000.0"/>
        <property name="department" ref="it"/>
        <property name="skills">
            <list>
                <ref bean="python"/>
            </list>
        </property>
    </bean>

    <bean id="emp4" class="com.cognizant.springlearn.Employee">
        <property name="id" value="E004"/>
        <property name="name" value="Diana"/>
        <property name="salary" value="65000.0"/>
        <property name="department" ref="hr"/>
        <property name="skills">
            <list>
                <ref bean="java"/>
            </list>
        </property>
    </bean>

    <bean id="employeeList" class="java.util.ArrayList">
        <constructor-arg>
            <list>
                <ref bean="emp1"/>
                <ref bean="emp2"/>
                <ref bean="emp3"/>
                <ref bean="emp4"/>
            </list>
        </constructor-arg>
    </bean>

</beans>
